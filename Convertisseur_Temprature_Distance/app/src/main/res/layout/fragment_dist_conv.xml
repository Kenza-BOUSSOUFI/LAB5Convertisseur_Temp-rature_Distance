<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Convertisseur de Distance"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <RadioGroup
        android:id="@+id/dist_type_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/choice_km_to_miles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Km vers Miles" />

        <RadioButton
            android:id="@+id/choice_miles_to_km"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Miles vers Km" />
    </RadioGroup>

    <EditText
        android:id="@+id/field_dist_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Saisir la distance"
        android:inputType="numberDecimal" />

    <Button
        android:id="@+id/btn_compute_dist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Calculer" />

    <TextView
        android:id="@+id/txt_dist_res"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Résultat : --"
        android:textSize="18sp" />
</LinearLayout>