<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Convertisseur de Température"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <RadioGroup
        android:id="@+id/temp_mode_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <RadioButton
            android:id="@+id/radio_c_to_f"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="°C vers °F" />

        <RadioButton
            android:id="@+id/radio_f_to_c"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="°F vers °C" />
    </RadioGroup>

    <EditText
        android:id="@+id/input_temp_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Saisir la température"
        android:inputType="numberDecimal|numberSigned" />

    <Button
        android:id="@+id/btn_trigger_temp_conv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Convertir" />

    <TextView
        android:id="@+id/label_temp_output"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Résultat attendu ici"
        android:textSize="18sp" />
</LinearLayout>